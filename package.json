{
	"name": "cloud.vaitschulis.com",
	"version": "0.1.0",
	"private": false,
	"dependencies": {
		"@adobe/react-spectrum": "^3.15.1",
		"@craco/craco": "^5.9.0",
		"@headlessui/react": "^1.4.2",
		"@heroicons/react": "^1.0.5",
		"@spectrum-web-components/banner": "^0.7.1",
		"@spectrum-web-components/card": "^0.10.1",
		"@testing-library/jest-dom": "^5.16.0",
		"@testing-library/react": "^11.2.7",
		"@testing-library/user-event": "^12.8.3",
		"daisyui": "^1.16.2",
		"framer-motion": "^4.1.17",
		"react": "^17.0.2",
		"react-dom": "^17.0.2",
		"react-helmet": "^6.1.0",
		"react-lorem-ipsum": "^1.4.9",
		"react-parallax": "^3.3.0",
		"react-router": "^6.1.1",
		"react-router-dom": "^6.1.1",
		"react-scripts": "^4.0.3",
		"react-tabs": "^3.2.3",
		"react-text-loop": "^2.3.0",
		"react-tilt": "^0.1.4",
		"tailwindcss-border-gradients": "^2.0.3",
		"vanilla-tilt": "^1.7.2",
		"web-vitals": "^1.1.2"
	},
	"source": "src/index.html",
	"scripts": {
		"start": "react-scripts start",
		"build": "CI=false && npm run watch:css && react-scripts build",
		"test": "react-scripts test",
		"eject": "react-scripts eject",
		"watch:css": "postcss src/index.css -o public/index.css",
		"livewatch:css": "postcss src/index.css -o public/index.css -w",
		"watch": "chokidar \"./src/**/*.js\" -c \"npm run watch:css\"",
		"dev": "concurrently \"npm run livewatch:css\" \"CI=false && npm run start\"",
		"storybook": "start-storybook -p 6006 -s public",
		"build-storybook": "build-storybook -s public"
	},
	"eslintConfig": {
		"extends": [
			"react-app",
			"react-app/jest"
		],
		"overrides": [
			{
				"files": [
					"**/*.stories.*"
				],
				"rules": {
					"import/no-anonymous-default-export": "off"
				}
			}
		]
	},
	"browserslist": {
		"production": [
			">0.2%",
			"not dead",
			"not op_mini all"
		],
		"development": [
			"last 1 chrome version",
			"last 1 firefox version",
			"last 1 safari version"
		]
	},
	"devDependencies": {
		"@storybook/addon-actions": "^6.4.9",
		"@storybook/addon-essentials": "^6.4.9",
		"@storybook/addon-links": "^6.4.9",
		"@storybook/node-logger": "^6.4.9",
		"@storybook/preset-create-react-app": "^3.2.0",
		"@storybook/react": "^6.4.9",
		"@tailwindcss/aspect-ratio": "^0.4.0",
		"@tailwindcss/forms": "^0.4.0",
		"@tailwindcss/line-clamp": "^0.3.0",
		"@tailwindcss/typography": "^0.5.0",
		"autoprefixer": "^10.4.0",
		"chokidar-cli": "^3.0.0",
		"concurrently": "^6.4.0",
		"parcel": "^2.0.1",
		"postcss": "^8.4.4",
		"postcss-cli": "^9.0.2",
		"react-tooltip": "^4.2.21",
		"tailwind-scrollbar": "^1.3.1",
		"tailwindcss": "^3.0.1"
	}
}
